PORT=5000
NODE_ENV=development
SESSION_SECRET=change-me
# Supports exact origins and wildcard subdomains such as https://*.mbktechnologies.info
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://mbktechnologies.info,https://www.mbktechnologies.info,https://*.mbktechnologies.info

# Google Drive Service Account - provide as JSON file at ./config/google-drive-service-account.json
# Required fields: type, project_id, private_key_id, private_key, client_email, client_id, auth_uri, token_uri, auth_provider_x509_cert_url, client_x509_cert_url, universe_domain
GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY_PATH=./config/google-drive-service-account.json
GOOGLE_DRIVE_TRAINER_DOCUMENTS_FOLDER_ID=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_TRAINING_ROOT_FOLDER_ID=
GOOGLE_DRIVE_TRAINING_PARENT_FOLDER_ID=
GOOGLE_DRIVE_TRAINING_ROOT_FOLDER_NAME=Trainer-Uploads
# Optional: service_account | oauth2 (default auto prefers service account when key is available)
GOOGLE_DRIVE_AUTH_MODE=service_account
GOOGLE_DRIVE_IMPERSONATE_USER_EMAIL=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_OAUTH_REDIRECT_URI=http://localhost:5001/oauth2callback
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_CHAT_WEBHOOK_URL=

JWT_SECRET=change-me-in-production
MSG91_AUTH_KEY=
# Set to 1 in local dev only when SMTP is unavailable (never in production)
ALLOW_OTP_DEBUG=0

STREAM_CHAT_API_KEY=
STREAM_CHAT_API_SECRET=
STREAM_CHAT_ANNOUNCEMENT_CHANNEL_ID=portal-announcements

# Redis is optional during local development. Set REDIS_URL when Redis is available.
REDIS_URL=redis://localhost:6379
DISABLE_REDIS=1

# SMS / OTP (Plivo) - https://console.plivo.com
# Set DISABLE_SMS=1 for local dev (OTP codes log to the backend console).
DISABLE_SMS=1
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_SOURCE_NUMBER=
PLIVO_SENDER_ID=
DLT_ENTITY_ID=
DLT_TE_ID_VERIFICATION=
DLT_TE_ID_RESET=
